  <data name="Results_PageTitle.Text" xml:space="preserve"><value>Ergebnisse</value></data>
  <data name="Results_SaveProject.Content" xml:space="preserve"><value>Projekt speichern</value></data>
  <data name="Results_NewMeasurement.Content" xml:space="preserve"><value>Neue Messung</value></data>
