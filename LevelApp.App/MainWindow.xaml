<Window
    x:Class="LevelApp.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Menu bar ──────────────────────────────────────────────────────── -->
        <MenuBar Grid.Row="0">

            <MenuBarItem Title="File">
                <MenuFlyoutItem Text="New Project"
                                Command="{x:Bind ViewModel.NewProjectCommand}"/>
                <MenuFlyoutItem Text="Open Project..."
                                Command="{x:Bind ViewModel.OpenProjectCommand}"/>
                <MenuFlyoutItem Text="Save Project"
                                Command="{x:Bind ViewModel.SaveProjectCommand}"/>
                <MenuFlyoutItem Text="Save Project As..."
                                Command="{x:Bind ViewModel.SaveProjectAsCommand}"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Exit"
                                Command="{x:Bind ViewModel.ExitCommand}"/>
            </MenuBarItem>

            <MenuBarItem Title="Settings">
                <MenuFlyoutItem Text="Preferences..."
                                Click="OnPreferencesClicked"/>
            </MenuBarItem>

            <MenuBarItem Title="Help">
                <MenuFlyoutItem Text="About LevelApp..."
                                Click="OnAboutClicked"/>
            </MenuBarItem>

        </MenuBar>

        <!-- ── Navigation host ───────────────────────────────────────────────── -->
        <Frame x:Name="RootFrame" Grid.Row="1"/>

    </Grid>

</Window>
