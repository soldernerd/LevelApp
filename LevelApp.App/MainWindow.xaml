<Window
    x:Class="LevelApp.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Menu bar ──────────────────────────────────────────────────────── -->
        <MenuBar Grid.Row="0">

            <MenuBarItem x:Uid="Menu_File">
                <MenuFlyoutItem x:Uid="Menu_File_NewProject"
                                Command="{x:Bind ViewModel.NewProjectCommand}"/>
                <MenuFlyoutItem x:Uid="Menu_File_OpenProject"
                                Command="{x:Bind ViewModel.OpenProjectCommand}"/>
                <MenuFlyoutItem x:Uid="Menu_File_SaveProject"
                                Command="{x:Bind ViewModel.SaveProjectCommand}"/>
                <MenuFlyoutItem x:Uid="Menu_File_SaveProjectAs"
                                Command="{x:Bind ViewModel.SaveProjectAsCommand}"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem x:Uid="Menu_File_Exit"
                                Command="{x:Bind ViewModel.ExitCommand}"/>
            </MenuBarItem>

            <MenuBarItem x:Uid="Menu_Edit">
                <MenuFlyoutItem x:Uid="Menu_Edit_Preferences"
                                Click="OnPreferencesClicked"/>
            </MenuBarItem>

            <MenuBarItem x:Uid="Menu_Help">
                <MenuFlyoutItem x:Uid="Menu_Help_About"
                                Click="OnAboutClicked"/>
            </MenuBarItem>

        </MenuBar>

        <!-- ── Navigation host ───────────────────────────────────────────────── -->
        <Frame x:Name="RootFrame" Grid.Row="1"/>

    </Grid>

</Window>
