<ContentDialog
    x:Class="LevelApp.App.Views.Dialogs.RecalculateDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    DefaultButton="Primary">

    <StackPanel Spacing="16" MinWidth="420">

        <!-- Calculation method -->
        <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock x:Uid="Recalculate_Method_Label"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Uid="Recalculate_Method_Tooltip"/>
                    </ToolTipService.ToolTip>
                </TextBlock>
                <Button Style="{StaticResource HelpButtonStyle}">
                    <Button.Flyout>
                        <Flyout Placement="Bottom">
                            <StackPanel MaxWidth="340" Spacing="8">
                                <TextBlock x:Uid="CalcMethod_Help_Title" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                <TextBlock x:Uid="CalcMethod_Help_Body" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
            <ComboBox x:Name="MethodCombo"
                      SelectedIndex="0"
                      HorizontalAlignment="Stretch">
                <ComboBoxItem x:Uid="Recalculate_Method_LeastSquares"/>
                <ComboBoxItem x:Uid="Recalculate_Method_Sequential"/>
            </ComboBox>
            <!-- Sequential Integration and Linear Drift info buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                <Button Style="{StaticResource HelpButtonStyle}">
                    <Button.Flyout>
                        <Flyout Placement="Bottom">
                            <StackPanel MaxWidth="340" Spacing="8">
                                <TextBlock x:Uid="SeqIntegration_Help_Title" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                <TextBlock x:Uid="SeqIntegration_Help_Body" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button Style="{StaticResource HelpButtonStyle}">
                    <Button.Flyout>
                        <Flyout Placement="Bottom">
                            <StackPanel MaxWidth="340" Spacing="8">
                                <TextBlock x:Uid="LinearDrift_Help_Title" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                <TextBlock x:Uid="LinearDrift_Help_Body" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </StackPanel>

        <!-- Auto-exclude outliers -->
        <StackPanel Spacing="4">
            <TextBlock x:Uid="Recalculate_AutoExclude_Label"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                <ToolTipService.ToolTip>
                    <ToolTip x:Uid="Recalculate_AutoExclude_Tooltip"/>
                </ToolTipService.ToolTip>
            </TextBlock>
            <ToggleSwitch x:Name="AutoExcludeToggle"
                          IsOn="True"
                          Toggled="OnAutoExcludeToggled"/>
        </StackPanel>

        <!-- Sigma threshold (conditional) -->
        <StackPanel Spacing="4">
            <TextBlock x:Uid="Recalculate_SigmaThreshold_Label"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <NumberBox x:Name="SigmaBox"
                       Value="2.5"
                       Minimum="1.0"
                       Maximum="10.0"
                       SmallChange="0.1"
                       SpinButtonPlacementMode="Compact"
                       HorizontalAlignment="Stretch"/>
        </StackPanel>

        <!-- Flagged steps (manual exclusion) -->
        <StackPanel x:Name="FlaggedPanel" Spacing="8">
            <TextBlock Text="Flagged steps (uncheck to exclude manually)"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <ItemsControl x:Name="FlaggedList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Label}"
                                  IsChecked="{Binding IsIncluded, Mode=TwoWay}"
                                  Margin="0,2,0,2"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

    </StackPanel>

</ContentDialog>
