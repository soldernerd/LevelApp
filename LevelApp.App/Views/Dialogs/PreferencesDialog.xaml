<ContentDialog
    x:Class="LevelApp.App.Views.Dialogs.PreferencesDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Uid="PrefsDlg"
    DefaultButton="Primary"
    PrimaryButtonClick="OnOkClicked"
    SecondaryButtonClick="OnCancelClicked">

    <StackPanel Spacing="16" MinWidth="440">

        <!-- Default project folder -->
        <TextBlock x:Uid="Preferences_DefaultFolder_Label"
                   Style="{StaticResource BodyStrongTextBlockStyle}">
            <ToolTipService.ToolTip>
                <ToolTip x:Uid="Preferences_DefaultFolder_Tooltip"/>
            </ToolTipService.ToolTip>
        </TextBlock>

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox x:Name="FolderPathBox"
                     Grid.Column="0"
                     IsReadOnly="True"
                     PlaceholderText="Select a folder…"/>
            <Button Grid.Column="1"
                    x:Uid="Preferences_BrowseFolder"
                    Click="OnBrowseClicked"
                    VerticalAlignment="Bottom"/>
        </Grid>

        <StackPanel Spacing="8">
            <TextBlock x:Uid="Preferences_Theme_Label"
                       Style="{StaticResource SectionHeaderStyle}"/>
            <RadioButtons SelectedIndex="{x:Bind ThemeIndex, Mode=TwoWay}">
                <RadioButton x:Uid="Preferences_Theme_System"/>
                <RadioButton x:Uid="Preferences_Theme_Light"/>
                <RadioButton x:Uid="Preferences_Theme_Dark"/>
            </RadioButtons>
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock x:Uid="Preferences_Language_Label"
                       Style="{StaticResource SectionHeaderStyle}"/>
            <RadioButtons SelectedIndex="{x:Bind LanguageIndex, Mode=TwoWay}">
                <RadioButton x:Uid="Preferences_Language_System"/>
                <RadioButton x:Uid="Preferences_Language_English"/>
                <RadioButton x:Uid="Preferences_Language_Deutsch"/>
            </RadioButtons>
            <TextBlock x:Uid="Preferences_Language_RestartNote"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

    </StackPanel>

</ContentDialog>
