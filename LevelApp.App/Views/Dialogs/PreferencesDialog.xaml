<ContentDialog
    x:Class="LevelApp.App.Views.Dialogs.PreferencesDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Preferences"
    PrimaryButtonText="OK"
    SecondaryButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonClick="OnOkClicked">

    <StackPanel Spacing="16" MinWidth="440">

        <TextBlock Text="Default project folder"
                   Style="{StaticResource BodyStrongTextBlockStyle}"/>

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox x:Name="FolderPathBox"
                     Grid.Column="0"
                     IsReadOnly="True"
                     PlaceholderText="Select a folder…"/>
            <Button Grid.Column="1"
                    Content="Browse…"
                    Click="OnBrowseClicked"
                    VerticalAlignment="Bottom"/>
        </Grid>

    </StackPanel>

</ContentDialog>
