<ContentDialog
    x:Class="LevelApp.App.Views.Dialogs.NewMeasurementDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    DefaultButton="Primary">

    <StackPanel Spacing="16" MinWidth="400">

        <!-- Read-only geometry summary -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="12">
            <StackPanel Spacing="4">
                <TextBlock Text="Object (read-only)"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="GeometrySummaryText"
                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
            </StackPanel>
        </Border>

        <!-- Label -->
        <StackPanel Spacing="4">
            <TextBlock x:Uid="NewMeasurement_Label_Label"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBox x:Name="LabelBox"
                     PlaceholderText="Optional label"/>
        </StackPanel>

        <!-- Operator -->
        <StackPanel Spacing="4">
            <TextBlock x:Uid="NewMeasurement_Operator_Label"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBox x:Name="OperatorBox"
                     PlaceholderText="Your name"/>
        </StackPanel>

        <!-- Notes -->
        <StackPanel Spacing="4">
            <TextBlock x:Uid="NewMeasurement_Notes_Label"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBox x:Name="NotesBox"
                     PlaceholderText="Optional"
                     AcceptsReturn="True"
                     Height="60"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Strategy -->
        <ComboBox x:Name="StrategyCombo"
                  Header="Strategy"
                  SelectedIndex="0"
                  HorizontalAlignment="Stretch">
            <ComboBoxItem x:Uid="Strategy_FullGrid"/>
            <ComboBoxItem x:Uid="Strategy_UnionJack"/>
        </ComboBox>

    </StackPanel>

</ContentDialog>
