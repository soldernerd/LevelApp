<Page
    x:Class="LevelApp.App.Views.ProjectSetupView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:LevelApp.App.ViewModels"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid ColumnDefinitions="*,Auto">

        <!-- ── Left: setup form ─────────────────────────────────────────────── -->
        <ScrollViewer Grid.Column="0" Padding="0,0,16,0">
            <StackPanel Padding="40,32,40,40"
                        MaxWidth="480"
                        HorizontalAlignment="Center"
                        Spacing="0">

                <!-- ── Title ─────────────────────────────────────────────── -->
                <TextBlock x:Uid="ProjectSetup_PageTitle"
                           Style="{StaticResource TitleTextBlockStyle}"
                           Margin="0,0,0,32"/>

                <!-- ── Project Information ───────────────────────────────── -->
                <TextBlock x:Uid="ProjectInfo_SectionHeader"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Margin="0,0,0,12"/>

                <StackPanel Spacing="4" Margin="0,0,0,8">
                    <TextBlock x:Uid="ProjectName_Label"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <ToolTipService.ToolTip>
                            <ToolTip x:Uid="ProjectName_Label_Tooltip"/>
                        </ToolTipService.ToolTip>
                    </TextBlock>
                    <TextBox PlaceholderText="e.g. Granite plate workshop 3"
                             Text="{x:Bind ViewModel.ProjectName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Spacing="4" Margin="0,0,0,8">
                    <TextBlock x:Uid="Operator_Label"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <ToolTipService.ToolTip>
                            <ToolTip x:Uid="Operator_Label_Tooltip"/>
                        </ToolTipService.ToolTip>
                    </TextBlock>
                    <TextBox PlaceholderText="Your name"
                             Text="{x:Bind ViewModel.OperatorName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Spacing="4" Margin="0,0,0,32">
                    <TextBlock x:Uid="Notes_Label"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <ToolTipService.ToolTip>
                            <ToolTip x:Uid="Notes_Label_Tooltip"/>
                        </ToolTipService.ToolTip>
                    </TextBlock>
                    <TextBox PlaceholderText="Optional"
                             Text="{x:Bind ViewModel.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             Height="72"
                             TextWrapping="Wrap"/>
                </StackPanel>

                <!-- ── Object ─────────────────────────────────────────────── -->
                <TextBlock x:Uid="Object_SectionHeader"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Margin="0,0,0,12"/>

                <StackPanel Spacing="4" Margin="0,0,0,8">
                    <TextBlock x:Uid="GeometryType_Label"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <ToolTipService.ToolTip>
                            <ToolTip x:Uid="GeometryType_Label_Tooltip"/>
                        </ToolTipService.ToolTip>
                    </TextBlock>
                    <ComboBox SelectedIndex="{x:Bind ViewModel.SelectedGeometryIndex, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="OnGeometryChanged">
                        <ComboBoxItem x:Uid="GeometryType_SurfacePlate"/>
                        <ComboBoxItem x:Uid="GeometryType_ParallelWays"/>
                    </ComboBox>
                </StackPanel>

                <!-- Surface Plate: width/height -->
                <Grid ColumnSpacing="12"
                      Margin="0,0,0,32"
                      Visibility="{x:Bind ViewModel.IsSurfacePlate, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock x:Uid="Width_Label"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <ToolTipService.ToolTip>
                                <ToolTip x:Uid="Width_Label_Tooltip"/>
                            </ToolTipService.ToolTip>
                        </TextBlock>
                        <NumberBox Value="{x:Bind ViewModel.WidthMm, Mode=TwoWay}"
                                   Minimum="10" SmallChange="10" LargeChange="100"
                                   SpinButtonPlacementMode="Compact"
                                   ValueChanged="OnParameterChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock x:Uid="Height_Label"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <ToolTipService.ToolTip>
                                <ToolTip x:Uid="Height_Label_Tooltip"/>
                            </ToolTipService.ToolTip>
                        </TextBlock>
                        <NumberBox Value="{x:Bind ViewModel.HeightMm, Mode=TwoWay}"
                                   Minimum="10" SmallChange="10" LargeChange="100"
                                   SpinButtonPlacementMode="Compact"
                                   ValueChanged="OnParameterChanged"/>
                    </StackPanel>
                </Grid>

                <!-- Parallel Ways: orientation + rails -->
                <StackPanel Margin="0,0,0,32"
                            Spacing="8"
                            Visibility="{x:Bind ViewModel.IsParallelWays, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="PW_Orientation_Label"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <ToolTipService.ToolTip>
                                <ToolTip x:Uid="PW_Orientation_Tooltip"/>
                            </ToolTipService.ToolTip>
                        </TextBlock>
                        <ComboBox SelectedIndex="{x:Bind ViewModel.WaysOrientationIndex, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnParallelWaysComboChanged">
                            <ComboBoxItem>Horizontal</ComboBoxItem>
                            <ComboBoxItem>Vertical</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock x:Uid="PW_Rails_SectionHeader"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Margin="0,8,0,0"/>

                    <ItemsControl ItemsSource="{x:Bind ViewModel.RailItems, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:RailViewModel">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10,8"
                                        Margin="0,0,0,6">
                                    <StackPanel Spacing="6">
                                        <!-- Label, IsReference, Remove -->
                                        <Grid ColumnSpacing="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     PlaceholderText="Rail label"
                                                     Text="{x:Bind Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <CheckBox Grid.Column="1"
                                                      Content="Ref"
                                                      IsChecked="{x:Bind IsReference, Mode=OneWay}"
                                                      VerticalAlignment="Center"
                                                      Click="OnRailIsReferenceClick"/>
                                            <Button Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    Click="OnRemoveRailClick">
                                                <FontIcon Glyph="&#xE711;" FontSize="12"/>
                                            </Button>
                                        </Grid>
                                        <!-- Length, Lateral Sep -->
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="4">
                                                <TextBlock x:Uid="PW_RailLength_Label"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                    <ToolTipService.ToolTip>
                                                        <ToolTip x:Uid="PW_RailLength_Tooltip"/>
                                                    </ToolTipService.ToolTip>
                                                </TextBlock>
                                                <NumberBox Value="{x:Bind LengthMm, Mode=TwoWay}"
                                                           Minimum="1" SmallChange="100" LargeChange="500"
                                                           SpinButtonPlacementMode="Compact"
                                                           ValueChanged="OnParallelWaysNumberChanged"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <TextBlock x:Uid="PW_RailSeparation_Label"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                    <ToolTipService.ToolTip>
                                                        <ToolTip x:Uid="PW_RailSeparation_Tooltip"/>
                                                    </ToolTipService.ToolTip>
                                                </TextBlock>
                                                <NumberBox Value="{x:Bind LateralSeparationMm, Mode=TwoWay}"
                                                           Minimum="0" SmallChange="50" LargeChange="200"
                                                           SpinButtonPlacementMode="Compact"
                                                           ValueChanged="OnParallelWaysNumberChanged"/>
                                            </StackPanel>
                                        </Grid>
                                        <!-- Vert Offset, Axial Offset -->
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <NumberBox Grid.Column="0"
                                                       Header="Vert. offset (mm)"
                                                       Value="{x:Bind VerticalOffsetMm, Mode=TwoWay}"
                                                       SmallChange="10" LargeChange="50"
                                                       SpinButtonPlacementMode="Compact"
                                                       ValueChanged="OnParallelWaysNumberChanged"/>
                                            <NumberBox Grid.Column="1"
                                                       Header="Axial offset (mm)"
                                                       Value="{x:Bind AxialOffsetMm, Mode=TwoWay}"
                                                       SmallChange="10" LargeChange="50"
                                                       SpinButtonPlacementMode="Compact"
                                                       ValueChanged="OnParallelWaysNumberChanged"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button x:Uid="PW_AddRail_Button"
                            Command="{x:Bind ViewModel.AddRailCommand}"
                            HorizontalAlignment="Left"/>

                </StackPanel>

                <!-- ── Strategy ──────────────────────────────────────────── -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                    <TextBlock x:Uid="Strategy_SectionHeader"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <Button Style="{StaticResource HelpButtonStyle}">
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <StackPanel MaxWidth="340" Spacing="8">
                                    <TextBlock x:Uid="Strategy_Help_Title" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                    <TextBlock x:Uid="Strategy_Help_Body" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>

                <!-- Surface Plate strategy selector + params -->
                <StackPanel Spacing="0"
                            Visibility="{x:Bind ViewModel.IsSurfacePlate, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <StackPanel Spacing="4" Margin="0,0,0,12">
                        <TextBlock x:Uid="Strategy_Label"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <ToolTipService.ToolTip>
                                <ToolTip x:Uid="Strategy_Label_Tooltip"/>
                            </ToolTipService.ToolTip>
                        </TextBlock>
                        <ComboBox SelectedIndex="{x:Bind ViewModel.SelectedStrategyIndex, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnStrategyChanged">
                            <ComboBoxItem x:Uid="Strategy_FullGrid"/>
                            <ComboBoxItem x:Uid="Strategy_UnionJack"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Strategy ⓘ help buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                        <Button Style="{StaticResource HelpButtonStyle}">
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <StackPanel MaxWidth="340" Spacing="8">
                                        <TextBlock x:Uid="FullGrid_Help_Title" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                        <TextBlock x:Uid="FullGrid_Help_Body" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"/>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <Button Style="{StaticResource HelpButtonStyle}">
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <StackPanel MaxWidth="340" Spacing="8">
                                        <TextBlock x:Uid="UnionJack_Help_Title" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                        <TextBlock x:Uid="UnionJack_Help_Body" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"/>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>

                    <!-- Full Grid parameters -->
                    <Grid ColumnSpacing="12"
                          Margin="0,0,0,12"
                          Visibility="{x:Bind ViewModel.IsFullGrid, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock x:Uid="Columns_Label"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <ToolTipService.ToolTip>
                                    <ToolTip x:Uid="Columns_Label_Tooltip"/>
                                </ToolTipService.ToolTip>
                            </TextBlock>
                            <NumberBox Value="{x:Bind ViewModel.ColumnsCount, Mode=TwoWay}"
                                       Minimum="2" Maximum="50"
                                       SmallChange="1" LargeChange="5"
                                       SpinButtonPlacementMode="Compact"
                                       ValueChanged="OnParameterChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock x:Uid="Rows_Label"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <ToolTipService.ToolTip>
                                    <ToolTip x:Uid="Rows_Label_Tooltip"/>
                                </ToolTipService.ToolTip>
                            </TextBlock>
                            <NumberBox Value="{x:Bind ViewModel.RowsCount, Mode=TwoWay}"
                                       Minimum="2" Maximum="50"
                                       SmallChange="1" LargeChange="5"
                                       SpinButtonPlacementMode="Compact"
                                       ValueChanged="OnParameterChanged"/>
                        </StackPanel>
                    </Grid>

                    <!-- Union Jack parameters -->
                    <Grid ColumnSpacing="12"
                          Margin="0,0,0,12"
                          Visibility="{x:Bind ViewModel.IsUnionJack, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <NumberBox Grid.Column="0"
                                   Header="Segments"
                                   Value="{x:Bind ViewModel.Segments, Mode=TwoWay}"
                                   Minimum="1" Maximum="20"
                                   SmallChange="1" LargeChange="2"
                                   SpinButtonPlacementMode="Compact"
                                   ValueChanged="OnParameterChanged"/>
                        <ComboBox Grid.Column="1"
                                  Header="Rings"
                                  SelectedIndex="{x:Bind ViewModel.UnionJackRingsIndex, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnRingsOptionChanged">
                            <ComboBoxItem>None</ComboBoxItem>
                            <ComboBoxItem>Circumference</ComboBoxItem>
                            <ComboBoxItem>Full</ComboBoxItem>
                        </ComboBox>
                    </Grid>

                </StackPanel>

                <!-- Parallel Ways strategy: tasks + algorithm settings -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.IsParallelWays, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock x:Uid="PW_Tasks_SectionHeader"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>

                    <ItemsControl ItemsSource="{x:Bind ViewModel.TaskItems, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TaskViewModel">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10,8"
                                        Margin="0,0,0,6">
                                    <StackPanel Spacing="6">
                                        <!-- Type, Pass, Up/Down/Remove -->
                                        <Grid ColumnSpacing="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0"
                                                      Header="Type"
                                                      SelectedIndex="{x:Bind TaskTypeIndex, Mode=TwoWay}"
                                                      HorizontalAlignment="Stretch"
                                                      SelectionChanged="OnTaskTypeChanged">
                                                <ComboBoxItem x:Uid="PW_TaskType_AlongRail"/>
                                                <ComboBoxItem x:Uid="PW_TaskType_Bridge"/>
                                            </ComboBox>
                                            <ComboBox Grid.Column="1"
                                                      Header="Pass"
                                                      SelectedIndex="{x:Bind PassDirectionIndex, Mode=TwoWay}"
                                                      HorizontalAlignment="Stretch"
                                                      SelectionChanged="OnParallelWaysComboChanged">
                                                <ComboBoxItem>Single</ComboBoxItem>
                                                <ComboBoxItem>Fwd + Return</ComboBoxItem>
                                            </ComboBox>
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        Spacing="2"
                                                        VerticalAlignment="Bottom">
                                                <Button Click="OnMoveTaskUpClick" Padding="6,4">
                                                    <FontIcon Glyph="&#xE74A;" FontSize="11"/>
                                                </Button>
                                                <Button Click="OnMoveTaskDownClick" Padding="6,4">
                                                    <FontIcon Glyph="&#xE74B;" FontSize="11"/>
                                                </Button>
                                                <Button Click="OnRemoveTaskClick" Padding="6,4">
                                                    <FontIcon Glyph="&#xE711;" FontSize="11"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                        <!-- Step distance (all tasks) -->
                                        <NumberBox Header="Step distance (mm)"
                                                   Value="{x:Bind StepDistanceMm, Mode=TwoWay}"
                                                   Minimum="1" SmallChange="50" LargeChange="200"
                                                   SpinButtonPlacementMode="Compact"
                                                   ValueChanged="OnParallelWaysNumberChanged"/>
                                        <!-- Rail index (Along Rail) -->
                                        <NumberBox Header="Rail index"
                                                   Value="{x:Bind RailIndexA, Mode=TwoWay}"
                                                   Minimum="0" Maximum="99"
                                                   SmallChange="1" LargeChange="1"
                                                   SpinButtonPlacementMode="Compact"
                                                   ValueChanged="OnParallelWaysNumberChanged"
                                                   Visibility="{x:Bind IsAlongRail, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <!-- Rail indices (Bridge only) -->
                                        <Grid ColumnSpacing="8"
                                              Visibility="{x:Bind IsBridge, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <NumberBox Grid.Column="0"
                                                       Header="Rail A index"
                                                       Value="{x:Bind RailIndexA, Mode=TwoWay}"
                                                       Minimum="0" Maximum="99"
                                                       SmallChange="1" LargeChange="1"
                                                       SpinButtonPlacementMode="Compact"
                                                       ValueChanged="OnParallelWaysNumberChanged"/>
                                            <NumberBox Grid.Column="1"
                                                       Header="Rail B index"
                                                       Value="{x:Bind RailIndexB, Mode=TwoWay}"
                                                       Minimum="0" Maximum="99"
                                                       SmallChange="1" LargeChange="1"
                                                       SpinButtonPlacementMode="Compact"
                                                       ValueChanged="OnParallelWaysNumberChanged"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button x:Uid="PW_AddTask_Button"
                            Command="{x:Bind ViewModel.AddTaskCommand}"
                            HorizontalAlignment="Left"/>

                    <Grid ColumnSpacing="12" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock x:Uid="PW_DriftCorrection_Label"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <ToolTipService.ToolTip>
                                    <ToolTip x:Uid="PW_DriftCorrection_Tooltip"/>
                                </ToolTipService.ToolTip>
                            </TextBlock>
                            <ComboBox SelectedIndex="{x:Bind ViewModel.DriftCorrectionIndex, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="OnParallelWaysComboChanged">
                                <ComboBoxItem>First Station Anchor</ComboBoxItem>
                                <ComboBoxItem>Linear Drift Correction</ComboBoxItem>
                                <ComboBoxItem>Least Squares</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock x:Uid="PW_SolverMode_Label"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Button Style="{StaticResource HelpButtonStyle}">
                                    <Button.Flyout>
                                        <Flyout Placement="Bottom">
                                            <StackPanel MaxWidth="340" Spacing="8">
                                                <TextBlock x:Uid="PW_SolverMode_Help_Title" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                                <TextBlock x:Uid="PW_SolverMode_Help_Body" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"/>
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>
                            <ComboBox SelectedIndex="{x:Bind ViewModel.SolverModeIndex, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="OnParallelWaysComboChanged">
                                <ComboBoxItem>Independent + Reconcile</ComboBoxItem>
                                <ComboBoxItem>Global Least Squares</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                </StackPanel>

                <!-- Step-count preview -->
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            Margin="0,16,0,32">
                    <FontIcon Glyph="&#xE895;"
                              FontSize="14"
                              VerticalAlignment="Center"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.StepCountText, Mode=OneWay}"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- ── Action ─────────────────────────────────────────────── -->
                <Button x:Uid="StartMeasurement_Button"
                        Command="{x:Bind ViewModel.StartMeasurementCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Right"
                        Padding="24,8"/>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Right: live 2D preview ───────────────────────────────────────── -->
        <StackPanel Grid.Column="1"
                    Width="488"
                    Margin="0,32,32,32"
                    Padding="24"
                    Spacing="12">
            <TextBlock Text="Pattern Preview"
                       Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <ContentControl x:Name="PreviewContainer"
                            Content="{x:Bind ViewModel.PreviewCanvas, Mode=OneWay}"
                            HorizontalContentAlignment="Left"
                            VerticalContentAlignment="Top"/>
        </StackPanel>

    </Grid>

</Page>
