<Page
    x:Class="LevelApp.App.Views.ResultsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Padding="24,16,24,12"
              ColumnDefinitions="*,Auto,Auto">

            <TextBlock Grid.Column="0"
                       Text="{x:Bind ViewModel.ProjectName, Mode=OneWay}"
                       Style="{StaticResource TitleTextBlockStyle}"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    x:Uid="Results_Recalculate"
                    Click="OnRecalculateClicked"
                    Visibility="{x:Bind ViewModel.SurfacePlateOnlyVisibility, Mode=OneWay}"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0"/>

            <Button Grid.Column="2"
                    x:Uid="Results_NewMeasurement"
                    Click="OnNewMeasurementClicked"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- ── Main content ───────────────────────────────────────────────── -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,300"
              Padding="24,0,24,24"
              ColumnSpacing="24">

            <!-- Left: tabbed display (Tab 1 = 3D plot, Tab 2 = Measurements) -->
            <TabView Grid.Column="0"
                     IsAddTabButtonVisible="False"
                     TabWidthMode="Equal"
                     SelectionChanged="OnResultsTabSelectionChanged">
                <TabView.TabItems>

                <!-- ── Tab 1: 3D Surface Plot ─────────────────────────── -->
                <TabViewItem Header="3D Surface Plot" IsClosable="False">
                    <ScrollViewer HorizontalScrollMode="Auto"
                                  VerticalScrollMode="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="20">
                        <ContentControl x:Name="PlotContainer"
                                        HorizontalContentAlignment="Left"
                                        VerticalContentAlignment="Top"/>
                    </ScrollViewer>
                </TabViewItem>

                <!-- ── Tab 2: Measurements ───────────────────────────── -->
                <TabViewItem Header="Measurements" IsClosable="False">
                    <Grid RowDefinitions="Auto,*">

                        <!-- Controls row -->
                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Spacing="24"
                                    Padding="16,10,16,6">

                            <!-- Mode: Raw / Adjusted -->
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Mode:"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <RadioButton x:Name="RawModeRadio"
                                             Content="Raw"
                                             IsChecked="True"
                                             GroupName="MeasMode"
                                             Checked="OnModeOrUnitsChanged"/>
                                <RadioButton x:Name="AdjustedModeRadio"
                                             Content="Adjusted"
                                             GroupName="MeasMode"
                                             Checked="OnModeOrUnitsChanged"/>
                            </StackPanel>

                            <!-- Units are always µm -->
                            <TextBlock Text="Units: µm"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Grid canvas (mouse-wheel zooms, scroll bars pan) -->
                        <ScrollViewer Grid.Row="1"
                                      x:Name="MeasurementsScrollViewer"
                                      HorizontalScrollMode="Auto"
                                      VerticalScrollMode="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="16,0,16,16">
                            <Canvas x:Name="MeasurementsCanvas"
                                    Background="Transparent"
                                    PointerWheelChanged="OnMeasurementsCanvasWheel"/>
                        </ScrollViewer>

                    </Grid>
                </TabViewItem>

                </TabView.TabItems>
            </TabView>

            <!-- Right: info + statistics + flagged steps + correction -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16">

                    <!-- Object info card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Measurement Info"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       Margin="0,0,0,6"/>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowSpacing="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Object"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{x:Bind ViewModel.ObjectTypeText, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Dimensions"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{x:Bind ViewModel.DimensionsText, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Strategy"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{x:Bind ViewModel.StrategyText, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Grid / Segs"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1"
                                           Text="{x:Bind ViewModel.StrategyParamsText, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Method"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Row="4" Grid.Column="1"
                                           Text="{x:Bind ViewModel.CalcMethodText, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Threshold"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Row="5" Grid.Column="1"
                                           Text="{x:Bind ViewModel.SigmaThresholdText, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Excluded"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Row="6" Grid.Column="1"
                                           Text="{x:Bind ViewModel.ExcludedStepsText, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Flatness / Best Straightness card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel Spacing="4">
                            <!-- Label row with tooltip and ⓘ flyout -->
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock x:Uid="Flatness_Label"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           Visibility="{x:Bind ViewModel.SurfacePlateOnlyVisibility, Mode=OneWay}">
                                    <ToolTipService.ToolTip>
                                        <ToolTip x:Uid="Flatness_Label_Tooltip"/>
                                    </ToolTipService.ToolTip>
                                </TextBlock>
                                <TextBlock x:Uid="PW_BestStraightness_Label"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           Visibility="{x:Bind ViewModel.ParallelWaysOnlyVisibility, Mode=OneWay}"/>
                                <Button Style="{StaticResource HelpButtonStyle}">
                                    <Button.Flyout>
                                        <Flyout Placement="Bottom">
                                            <StackPanel MaxWidth="340" Spacing="8">
                                                <TextBlock x:Uid="Flatness_Help_Title" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                                <TextBlock x:Uid="Flatness_Help_Body" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"/>
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>
                            <!-- Value with tooltip -->
                            <TextBlock Text="{x:Bind ViewModel.FlatnessText, Mode=OneWay}"
                                       Style="{StaticResource SubtitleTextBlockStyle}">
                                <ToolTipService.ToolTip>
                                    <ToolTip x:Uid="FlatnessValue_Tooltip"/>
                                </ToolTipService.ToolTip>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Sigma card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel Spacing="4">
                            <!-- Label row with tooltip and ⓘ flyout -->
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock x:Uid="ResidualRMS_Label"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center">
                                    <ToolTipService.ToolTip>
                                        <ToolTip x:Uid="ResidualRMS_Label_Tooltip"/>
                                    </ToolTipService.ToolTip>
                                </TextBlock>
                                <Button Style="{StaticResource HelpButtonStyle}">
                                    <Button.Flyout>
                                        <Flyout Placement="Bottom">
                                            <StackPanel MaxWidth="340" Spacing="8">
                                                <TextBlock x:Uid="ResidualRMS_Help_Title" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                                <TextBlock x:Uid="ResidualRMS_Help_Body" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"/>
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>
                            <!-- Sigma value with tooltip -->
                            <TextBlock Text="{x:Bind ViewModel.SigmaText, Mode=OneWay}"
                                       Style="{StaticResource SubtitleTextBlockStyle}">
                                <ToolTipService.ToolTip>
                                    <ToolTip x:Uid="SigmaValue_Tooltip"/>
                                </ToolTipService.ToolTip>
                            </TextBlock>
                            <!-- Least-Squares Adjustment info row -->
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,4,0,0">
                                <Button Style="{StaticResource HelpButtonStyle}">
                                    <Button.Flyout>
                                        <Flyout Placement="Bottom">
                                            <StackPanel MaxWidth="340" Spacing="8">
                                                <TextBlock x:Uid="LeastSquares_Help_Title" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                                <TextBlock x:Uid="LeastSquares_Help_Body" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"/>
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Parallel Ways: per-rail and parallelism card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16"
                            Visibility="{x:Bind ViewModel.ParallelWaysOnlyVisibility, Mode=OneWay}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Straightness &amp; Parallelism"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{x:Bind ViewModel.ParallelismText, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Closure errors card (visible only when loops exist) -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16"
                            Visibility="{x:Bind ViewModel.ClosureStatsVisibility, Mode=OneWay}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Closure errors"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       Margin="0,0,0,4"/>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowSpacing="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Mean"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{x:Bind ViewModel.ClosureErrorMeanText, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Median"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{x:Bind ViewModel.ClosureErrorMedianText, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Max"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{x:Bind ViewModel.ClosureErrorMaxText, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="RMS"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1"
                                           Text="{x:Bind ViewModel.ClosureErrorRmsText, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Flagged steps card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel Spacing="8">
                            <!-- Header row with ⓘ flyout -->
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock x:Uid="Results_FlaggedSteps_Header"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           VerticalAlignment="Center"/>
                                <Button Style="{StaticResource HelpButtonStyle}">
                                    <Button.Flyout>
                                        <Flyout Placement="Bottom">
                                            <StackPanel MaxWidth="340" Spacing="8">
                                                <TextBlock x:Uid="FlaggedSteps_Help_Title" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                                <TextBlock x:Uid="FlaggedSteps_Help_Body" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"/>
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>
                            <!-- "No flagged steps" message (visible when list is empty) -->
                            <TextBlock x:Uid="Results_NoFlaggedSteps"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Visibility="{x:Bind ViewModel.NoFlaggedStepsVisibility, Mode=OneWay}"/>
                            <!-- Flagged steps list -->
                            <ItemsControl ItemsSource="{x:Bind ViewModel.FlaggedSteps, Mode=OneWay}"
                                          Visibility="{x:Bind ViewModel.FlaggedListVisibility, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Label}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Sigma threshold and correction round info row -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Button Style="{StaticResource HelpButtonStyle}">
                                    <Button.Flyout>
                                        <Flyout Placement="Bottom">
                                            <StackPanel MaxWidth="340" Spacing="8">
                                                <TextBlock x:Uid="SigmaThreshold_Help_Title" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                                <TextBlock x:Uid="SigmaThreshold_Help_Body" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"/>
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                                <Button Style="{StaticResource HelpButtonStyle}">
                                    <Button.Flyout>
                                        <Flyout Placement="Bottom">
                                            <StackPanel MaxWidth="340" Spacing="8">
                                                <TextBlock x:Uid="CorrectionRound_Help_Title" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                                <TextBlock x:Uid="CorrectionRound_Help_Body" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"/>
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Start Correction Session button (Surface Plate only) -->
                    <Button x:Uid="Results_StartCorrection"
                            Command="{x:Bind ViewModel.StartCorrectionSessionCommand}"
                            Visibility="{x:Bind ViewModel.CorrectButtonVisibility, Mode=OneWay}"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>

    </Grid>

</Page>
