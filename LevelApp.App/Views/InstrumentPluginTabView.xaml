<UserControl
    x:Class="LevelApp.App.Views.InstrumentPluginTabView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:LevelApp.App.ViewModels">

    <ScrollViewer Padding="0,16,0,24">
        <StackPanel Spacing="24" MaxWidth="600" Margin="0,0,0,0">

            <!-- ── Section: Known Devices ─────────────────────────────────────── -->
            <StackPanel Spacing="12">

                <TextBlock Text="Known Devices"
                           Style="{StaticResource SubtitleTextBlockStyle}"/>

                <!-- Device list — shown only when there are known devices -->
                <ItemsControl x:Name="DeviceList"
                              ItemsSource="{x:Bind ViewModel.KnownDevices, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:KnownDeviceViewModel">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="4"
                                    Padding="12,8"
                                    Margin="0,0,0,4">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind DisplayName}"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource BodyTextBlockStyle}"/>
                                    <Border Grid.Column="1"
                                            Background="{ThemeResource AccentFillColorTertiaryBrush}"
                                            CornerRadius="2"
                                            Padding="4,2"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind TransportLabel}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                    </Border>
                                    <Button Grid.Column="2"
                                            VerticalAlignment="Center"
                                            ToolTipService.ToolTip="Forget this device"
                                            Click="OnForgetDeviceClicked">
                                        <FontIcon Glyph="&#xE711;" FontSize="12"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <TextBlock x:Name="NoDevicesText"
                           Text="No devices registered."
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Visibility="Collapsed"/>

                <!-- Add Device button — hidden for always-connected plugins -->
                <Button x:Name="AddDeviceButton"
                        Content="+ Add Device"
                        Click="OnAddDeviceClicked"
                        Visibility="Collapsed"/>

            </StackPanel>

            <!-- ── Section: Actions ───────────────────────────────────────────── -->
            <StackPanel Spacing="8">

                <TextBlock Text="Actions"
                           Style="{StaticResource SubtitleTextBlockStyle}"/>

                <StackPanel Orientation="Horizontal" Spacing="8">

                    <Button x:Name="CalibrationButton"
                            Content="Calibration"
                            Click="OnCalibrationClicked"
                            Visibility="Collapsed"/>

                    <Button x:Name="FirmwareUpdateButton"
                            Content="Firmware Update"
                            Click="OnFirmwareUpdateClicked"
                            Visibility="Collapsed"/>

                </StackPanel>

            </StackPanel>

            <!-- ── Section: Plugin-specific view (if any) ────────────────────── -->
            <ContentPresenter x:Name="PluginSpecificContent"
                              Visibility="Collapsed"/>

        </StackPanel>
    </ScrollViewer>

</UserControl>
